{
  "config": {
    "flow_title": "iRobot Braava 240 ({name})",
    "step": {
      "bluetooth_confirm": {
        "title": "Braava 240 found",
        "description": "Do you want to add **{name}** to Home Assistant?"
      },
      "show_device_info": {
        "title": "Device Info",
        "description": "Successfully connected to **{name}**.\n\n**Hardware Version:** {hw_version}\n**Firmware Version:** {fw_version}\n**Serial Number:** {serial_number}\n\n**GATT Characteristics:**\n{characteristics}\n\nClick Submit to finish setup."
      }
    },
    "error": {
      "cannot_connect": "Failed to connect to the Braava 240. Make sure the robot is powered on and in range."
    },
    "abort": {
      "already_configured": "Device is already configured.",
      "no_devices_found": "No Braava 240 found. Make sure the robot is powered on.",
      "not_supported": "This device is not supported."
    }
  },
  "entity": {
    "vacuum": {},
    "sensor": {
      "robot_state": {
        "name": "Status",
        "state": {
          "idle": "Idle",
          "cleaning": "Cleaning",
          "error": "Error"
        }
      },
      "battery": {
        "name": "Battery"
      },
      "pad_type": {
        "name": "Cleaning Pad",
        "state": {
          "invalid": "Invalid",
          "damp": "Damp",
          "dry": "Dry",
          "wet": "Wet",
          "reusable_damp": "Reusable damp",
          "reusable_dry": "Reusable dry",
          "reusable_wet": "Reusable wet",
          "plate": "Plate",
          "all": "All",
          "no_pad": "No pad"
        }
      }
    },
    "select": {
      "cleaning_mode": {
        "name": "Cleaning Mode",
        "state": {
          "normal": "Normal",
          "spot": "Spot"
        }
      },
      "wetness_wet": {
        "name": "Wetness Wet Pad",
        "state": { "low": "Low", "medium": "Medium", "high": "High" }
      },
      "wetness_damp": {
        "name": "Wetness Damp Pad",
        "state": { "low": "Low", "medium": "Medium", "high": "High" }
